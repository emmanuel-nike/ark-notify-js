{
  "name": "@emmanuel-nike/ark-notify-js",
  "version": "0.1.0",
  "description": "JavaScript SDK for Ark Notify — real-time pub/sub, presence, and platform management",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "ark-notify-js",
    "realtime",
    "websocket",
    "sse",
    "pubsub",
    "presence",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ark-notify/ark-notify-js.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "any-promise": "^1.3.0",
    "bundle-require": "^5.1.0",
    "cac": "^6.7.14",
    "chokidar": "^4.0.3",
    "commander": "^4.1.1",
    "confbox": "^0.1.8",
    "consola": "^3.4.2",
    "csstype": "^3.2.3",
    "debug": "^4.4.3",
    "esbuild": "^0.27.7",
    "fdir": "^6.5.0",
    "fix-dts-default-cjs-exports": "^1.0.1",
    "joycon": "^3.1.1",
    "lilconfig": "^3.1.3",
    "lines-and-columns": "^1.2.4",
    "load-tsconfig": "^0.2.5",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "ms": "^2.1.3",
    "mz": "^2.7.0",
    "object-assign": "^4.1.1",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "pirates": "^4.0.7",
    "pkg-types": "^1.3.1",
    "postcss-load-config": "^6.0.1",
    "readdirp": "^4.1.2",
    "resolve-from": "^5.0.0",
    "rollup": "^4.62.0",
    "source-map": "^0.7.6",
    "sucrase": "^3.35.1",
    "thenify": "^3.3.1",
    "thenify-all": "^1.6.0",
    "tinyexec": "^0.3.2",
    "tinyglobby": "^0.2.17",
    "tree-kill": "^1.2.2",
    "ts-interface-checker": "^0.1.13",
    "ufo": "^1.6.4"
  },
  "author": "Emmanuel Nwankwo",
  "bugs": {
    "url": "https://github.com/ark-notify/ark-notify-js/issues"
  },
  "homepage": "https://github.com/ark-notify/ark-notify-js#readme"
}
