{
  "name": "@emmanuel-nike/ark-notify-js",
  "version": "0.2.0",
  "description": "JavaScript SDK for Ark Notify — real-time pub/sub, presence, and platform management",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "default": "./dist/react/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs",
      "default": "./dist/server/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": ["./dist/react/index.d.ts"],
      "server": ["./dist/server/index.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "ark-notify-js",
    "realtime",
    "websocket",
    "sse",
    "pubsub",
    "presence",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ark-notify/ark-notify-js.git"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Emmanuel Nwankwo",
  "bugs": {
    "url": "https://github.com/ark-notify/ark-notify-js/issues"
  },
  "homepage": "https://github.com/ark-notify/ark-notify-js#readme"
}
